<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include("partials/head", { titulo: "Admin" }) %>
</head>
<body>
  <div class="pagina-app">
    <div class="topo-app">
      <div class="marca">
        <svg class="marca-icone" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C12 2 8.5 6.5 8.5 10.5C8.5 12.9853 10.0147 15 12.5 15C14.9853 15 16.5 12.9853 16.5 10.5C16.5 9.5 16 8.5 16 8.5C16 8.5 15 10 14 10C13.2 10 13 9 13 8C13 6 12 2 12 2Z" fill="#D9A94F"/>
          <path d="M6 21C6 17 9 15 12 15C15 15 18 17 18 21" stroke="#D9A94F" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
        <span class="marca-nome">Discipulador<span class="ponto-ia">.IA</span></span>
      </div>
      <a href="/painel" class="botao botao-fantasma">Voltar</a>
    </div>

    <div class="cartao cartao-largo">
      <h1>Administração</h1>
      <p class="subtitulo">Estatísticas do sistema.</p>

      <div class="cartao" style="margin-top: 1.2rem;">
        <p><strong>Usuários cadastrados:</strong> <%= estatisticas.totalUsuarios %></p>
        <p><strong>Jornadas registradas:</strong> <%= estatisticas.totalJornadas %></p>
      </div>

      <div class="cartao" style="margin-top: 1.2rem;">
        <h2>Usuários</h2>
        <% if (usuarios && usuarios.length) { %>
          <ul style="padding-left: 1.2rem;">
            <% usuarios.forEach((usuario) => { %>
              <li style="margin-bottom: 0.8rem;">
                <strong><%= usuario.nome %></strong> — <%= usuario.email %><br>
                <small>Cadastrado em: <%= new Date(usuario.criadoEm).toLocaleString('pt-BR') %></small><br>
                <small>Jornadas: <%= usuario.totalJornadas %></small>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p>Nenhum usuário cadastrado.</p>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
