<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include("partials/head", { titulo: "Painel" }) %>
</head>
<body>
  <div class="pagina-app">
    <div class="topo-app">
      <div class="marca">
        <svg class="marca-icone" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C12 2 8.5 6.5 8.5 10.5C8.5 12.9853 10.0147 15 12.5 15C14.9853 15 16.5 12.9853 16.5 10.5C16.5 9.5 16 8.5 16 8.5C16 8.5 15 10 14 10C13.2 10 13 9 13 8C13 6 12 2 12 2Z" fill="#D9A94F"/>
          <path d="M6 21C6 17 9 15 12 15C15 15 18 17 18 21" stroke="#D9A94F" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
        <span class="marca-nome">Discipulador<span class="ponto-ia">.IA</span></span>
      </div>
      <form class="form-sair" method="POST" action="/logout">
        <button type="submit" class="botao botao-fantasma">Sair</button>
      </form>
    </div>

    <div class="estepper">
      <div class="estepper-etapa acesa">
        <svg class="estepper-chama" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C12 2 8.5 6.5 8.5 10.5C8.5 12.9853 10.0147 15 12.5 15C14.9853 15 16.5 12.9853 16.5 10.5C16.5 9.5 16 8.5 16 8.5C16 8.5 15 10 14 10C13.2 10 13 9 13 8C13 6 12 2 12 2Z" fill="#D9A94F"/></svg>
        <span class="estepper-rotulo">Sentimento</span>
      </div>
      <div class="estepper-linha"></div>
      <div class="estepper-etapa"><svg class="estepper-chama" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C12 2 8.5 6.5 8.5 10.5C8.5 12.9853 10.0147 15 12.5 15C14.9853 15 16.5 12.9853 16.5 10.5C16.5 9.5 16 8.5 16 8.5C16 8.5 15 10 14 10C13.2 10 13 9 13 8C13 6 12 2 12 2Z" fill="#D9A94F"/></svg><span class="estepper-rotulo">Palavra</span></div>
      <div class="estepper-linha"></div>
      <div class="estepper-etapa"><svg class="estepper-chama" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C12 2 8.5 6.5 8.5 10.5C8.5 12.9853 10.0147 15 12.5 15C14.9853 15 16.5 12.9853 16.5 10.5C16.5 9.5 16 8.5 16 8.5C16 8.5 15 10 14 10C13.2 10 13 9 13 8C13 6 12 2 12 2Z" fill="#D9A94F"/></svg><span class="estepper-rotulo">Versículo</span></div>
      <div class="estepper-linha"></div>
      <div class="estepper-etapa"><svg class="estepper-chama" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C12 2 8.5 6.5 8.5 10.5C8.5 12.9853 10.0147 15 12.5 15C14.9853 15 16.5 12.9853 16.5 10.5C16.5 9.5 16 8.5 16 8.5C16 8.5 15 10 14 10C13.2 10 13 9 13 8C13 6 12 2 12 2Z" fill="#D9A94F"/></svg><span class="estepper-rotulo">História</span></div>
      <div class="estepper-linha"></div>
      <div class="estepper-etapa"><svg class="estepper-chama" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C12 2 8.5 6.5 8.5 10.5C8.5 12.9853 10.0147 15 12.5 15C14.9853 15 16.5 12.9853 16.5 10.5C16.5 9.5 16 8.5 16 8.5C16 8.5 15 10 14 10C13.2 10 13 9 13 8C13 6 12 2 12 2Z" fill="#D9A94F"/></svg><span class="estepper-rotulo">Oração</span></div>
      <div class="estepper-linha"></div>
      <div class="estepper-etapa"><svg class="estepper-chama" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C12 2 8.5 6.5 8.5 10.5C8.5 12.9853 10.0147 15 12.5 15C14.9853 15 16.5 12.9853 16.5 10.5C16.5 9.5 16 8.5 16 8.5C16 8.5 15 10 14 10C13.2 10 13 9 13 8C13 6 12 2 12 2Z" fill="#D9A94F"/></svg><span class="estepper-rotulo">Discipulado</span></div>
    </div>

    <div class="cartao cartao-largo">
      <h1>Olá, <%= nome %> 👋</h1>
      <p class="subtitulo">Como você está hoje? Pode escrever com liberdade — isso fica só entre você e Deus.</p>

      <% if (erro) { %>
        <div class="erro"><%= erro %></div>
      <% } %>

      <form method="POST" action="/painel/pergunta">
        <div class="campo">
          <label for="sentimento">Seu momento agora</label>
          <textarea id="sentimento" name="sentimento" placeholder="Ex: Estou ansioso com uma decisão que preciso tomar essa semana..." required autofocus></textarea>
        </div>
        <button type="submit" class="botao botao-primario" id="btnEnviar">Continuar</button>
      </form>
    </div>
  </div>

  <script>
    document.querySelector("form").addEventListener("submit", function () {
      const btn = document.getElementById("btnEnviar");
      btn.disabled = true;
      btn.textContent = "Preparando sua palavra...";
    });
  </script>
</body>
</html>
