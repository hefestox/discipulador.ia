# Chave da API da Groq (https://console.groq.com/keys)
GROQ_API_KEY=coloque_sua_chave_aqui

# Modelo da Groq usado para gerar a palavra motivacional
GROQ_MODEL=llama-3.3-70b-versatile

# Segredo usado para assinar o cookie de sessão (troque por um valor aleatório e longo)
SESSION_SECRET=troque_este_valor_por_algo_bem_secreto

# Porta local (a Railway define PORT automaticamente em produção)
PORT=3000
